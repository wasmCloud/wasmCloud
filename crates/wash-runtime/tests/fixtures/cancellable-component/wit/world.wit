package wasmcloud:cancel-example;

interface producer {
    /// Mirror of the producer interface. The signature must match the
    /// `cancellable-producer` fixture exactly so the dynamic linker wires
    /// this import to the producer's export.
    produce: async func(n: u32) -> stream<u8>;
}

// wasi:http/handler@0.3.0 is exported as this component's incoming entrypoint.
// `control` is the host cancellation plugin (register the running invocation,
// then a separate request cancels it by id).
world canceller {
    import wasmcloud:cancellable-jobs/control@0.1.0;
    import producer;
    import wasi:http/types@0.3.0;
    import wasi:clocks/types@0.3.0;
    import wasi:random/random@0.3.0;

    export wasi:http/handler@0.3.0;
}
