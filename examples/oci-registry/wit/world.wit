package wasmcloud:oci-registry;

// An OCI registry served over wasip3 HTTP, backed by the async, native-stream
// `wasmcloud:blobstore@0.1.0` interface.
world oci-registry {
  import wasmcloud:blobstore/blobstore@0.1.0;
  import wasmcloud:blobstore/container@0.1.0;
  import wasmcloud:blobstore/types@0.1.0;

  // Random bytes for upload-session identifiers.
  import wasi:random/random@0.3.0;

  // HTTP entrypoint (wasip3 async handler).
  export wasi:http/handler@0.3.0;
}
