package wasmcloud:patch-stream@0.1.0;

interface types {
    variant op {
        add,
        remove,
        replace,
        move-op,
        copy-op,
        test,
    }

    /// One JSON Patch entry (RFC 6902). `value` is JSON-encoded so we
    /// don't have to model arbitrary JSON in WIT. For move / copy ops,
    /// `value` holds the source path.
    record patch {
        op: op,
        path: string,
        value: string,
    }
}

interface patches {
    use types.{patch};

    /// Subscribe to the patch stream. Returns NDJSON-encoded bytes
    /// (`stream<u8>`) rather than a typed `stream<patch>` — see README
    /// for the wasmtime cross-component-types bug that blocks the
    /// typed form. Declared `async func` so wit-bindgen lowers via
    /// the p3 async canonical ABI on both sides, matching wash's
    /// `func_new_concurrent` linker bridge.
    subscribe: async func() -> stream<u8>;
}

/// Stream sink: a downstream component takes ownership of a
/// cross-component `stream<u8>` and is responsible for draining it.
/// In this example, `meta-json` exports this interface and logs each
/// NDJSON patch line to stderr; the consumer (commander) hands the
/// patches stream off and forgets about it.
interface sink {
    send-stream: async func(s: stream<u8>) -> result;
}

world patch-producer {
    import wasi:clocks/monotonic-clock@0.3.0-rc-2026-03-15;

    export patches;
}

world patch-consumer {
    import patches;
    import sink;

    import wasi:http/types@0.3.0-rc-2026-03-15;
    import wasi:clocks/types@0.3.0-rc-2026-03-15;
    import wasi:random/random@0.3.0-rc-2026-03-15;

    export wasi:http/handler@0.3.0-rc-2026-03-15;
}

world meta-json {
    import patches;
    export sink;
    export wasmcloud:websocket/handler@0.1.0;
}
